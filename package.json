{
  "name": "@depfenderdev/mcp",
  "version": "0.1.0",
  "description": "Depfender MCP server for IDE integration - scan npm packages for security threats",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "depfender-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "depfender",
    "security",
    "npm",
    "exfiltration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/depfenderdev/mcp.git"
  },
  "homepage": "https://github.com/depfenderdev/mcp#readme",
  "bugs": {
    "url": "https://github.com/depfenderdev/mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ]
}
